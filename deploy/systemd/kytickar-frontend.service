[Unit]
Description=Kytickar Frontend (Vite Preview)
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=/home/__USER__/kytickar/app
ExecStart=/usr/bin/npm run preview -- --host 0.0.0.0 --port 5173
Restart=always
RestartSec=3
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
